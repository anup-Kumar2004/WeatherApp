<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/result_item_margin_bottom"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#fddcc3"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/result_item_padding_horizontal"
        android:paddingVertical="@dimen/result_item_padding_vertical">

        <ImageView
            android:layout_width="@dimen/result_icon_size"
            android:layout_height="@dimen/result_icon_size"
            android:src="@android:drawable/ic_menu_mylocation"
            android:contentDescription="Location"
            android:alpha="0.5"
            android:layout_marginEnd="@dimen/result_icon_margin_end"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvResultCityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1C1C1C"
                android:textSize="@dimen/result_city_text_size"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvResultCountry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/result_country_margin_top"
                android:textColor="#80573C"
                android:textSize="@dimen/result_country_text_size"
                android:fontFamily="sans-serif"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>