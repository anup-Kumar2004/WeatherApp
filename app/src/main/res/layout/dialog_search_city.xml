<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:paddingTop="@dimen/search_dialog_padding_top"
    android:paddingBottom="@dimen/search_dialog_padding_bottom"
    android:paddingStart="@dimen/search_dialog_padding_horizontal"
    android:paddingEnd="@dimen/search_dialog_padding_horizontal">

    <!-- ── Drag handle ── -->
    <View
        android:layout_width="@dimen/search_handle_width"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/search_handle_margin_top"
        android:layout_marginBottom="@dimen/search_handle_margin_bottom"
        android:background="#40000000"/>

    <!-- ── Title ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/search_title_margin_bottom"
        android:text="@string/search_city_2"
        android:textColor="#1C1C1C"
        android:textSize="@dimen/search_title_text_size"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <!-- ── Search input card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_input_height"
        app:cardBackgroundColor="#FFFFFFFF"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/search_dialog_padding_horizontal"
            android:paddingEnd="@dimen/search_input_margin_start">

            <ImageView
                android:layout_width="@dimen/search_icon_size"
                android:layout_height="@dimen/search_icon_size"
                android:src="@drawable/search_icon"
                android:contentDescription="Search"
                android:alpha="0.4"/>

            <EditText
                android:id="@+id/etCitySearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/search_input_margin_start"
                android:background="@null"
                android:hint="@string/type_a_city_name"
                android:textColor="#1C1C1C"
                android:textColorHint="#80573C"
                android:textSize="@dimen/search_input_text_size"
                android:fontFamily="sans-serif"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:maxLines="1"/>

            <ImageView
                android:id="@+id/btnClearSearch"
                android:layout_width="@dimen/search_icon_size"
                android:layout_height="@dimen/search_icon_size"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Clear"
                android:alpha="0.4"
                android:visibility="gone"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── Status hint text ── -->
    <TextView
        android:id="@+id/tvSearchHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/search_hint_margin_top"
        android:layout_marginBottom="@dimen/search_hint_margin_bottom"
        android:text="@string/type_at_least_2_characters"
        android:textColor="#80573C"
        android:textSize="@dimen/search_hint_text_size"
        android:fontFamily="sans-serif"
        android:visibility="visible"/>

    <!-- ── Results list ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/search_results_margin_top"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

</LinearLayout>